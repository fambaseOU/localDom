# 🪐 LocalDom Environment Template
# Copy this file to .env and fill in your values

# The WebSocket URL of your Relay (e.g., ws://your-vps-ip:9091)
# Use ws://localhost:9091 for local testing
RELAY_URL=ws://localhost:9091

# The Public HTTP Port for the Dashboard and API (Default: 9090)
PORT=9090

# The WebSocket Port for the Agent-to-Relay Bridge (Default: 9091)
WS_PORT=9091

# 🔒 End-to-End Encryption Secret
# Generate a long random string. Must be identical on both Relay and Agent.
ENCRYPTION_SECRET=your_long_random_secret_here_change_me
